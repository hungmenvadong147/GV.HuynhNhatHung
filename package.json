{
  "name": "learning-website",
  "version": "1.0.0",
  "description": "Website học tập với TypeScript và Cloudinary",
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --outfile=dist/app.js --format=esm --target=es2020",
    "watch": "esbuild src/app.ts --bundle --outfile=dist/app.js --format=esm --target=es2020 --watch",
    "dev": "npm run watch"
  },
  "keywords": ["learning", "education", "typescript", "cloudinary"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^5.3.3"
  }
}
