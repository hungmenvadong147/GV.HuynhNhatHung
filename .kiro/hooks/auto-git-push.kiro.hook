{
  "enabled": true,
  "name": "Auto Push to GitHub",
  "description": "Tự động commit và push tất cả thay đổi lên GitHub sau khi agent hoàn thành công việc",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"Auto commit: $(date '+%Y-%m-%d %H:%M:%S')\" && git push origin main",
    "timeout": 120
  }
}